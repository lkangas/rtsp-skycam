# Per-machine config — never committed (only .env differs per machine).
# Commit .env.example instead.
**/.env
.env
*.local.yaml

# Rendered config contains secrets (envsubst from the committed *.template).
# The template IS committed; the rendered copy is not.
config/config.yaml

# Secrets, certs, keys
*.pem
*.key
*.crt
secrets/

# Captured output — track the dir (so a fresh clone owns ./data as the cloning
# user, not root-created by Docker on first `up`), but ignore its contents.
/data/*
!/data/.gitkeep
/output/
*.jpg
*.jpeg
*.png

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Local-only notes — integration/ops plans that aren't part of the stacker
# software itself; kept out of the public repo.
docs/local/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
