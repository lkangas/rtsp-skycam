# Copy to `.env` on fresnel and fill in. `.env` is gitignored — never commit secrets.
# These variables are substituted into config/tapo.yaml.template and read by the
# supervisor at container start. Values below are placeholders / proposed defaults.

# --- Camera / RTSP -----------------------------------------------------------
# Tapo requires a dedicated "camera account" created in the Tapo app for RTSP.
# The main TP-Link cloud login does NOT work here.
TAPO_USERNAME=changeme
TAPO_PASSWORD=changeme
CAMERA_IP=192.168.1.50
CAMERA_PORT=554
# stream1 = main/full-res (recommended for detail), stream2 = substream/low-res
CAMERA_STREAM=stream1

# --- Site / sun gate ---------------------------------------------------------
LATITUDE=68.5
LONGITUDE=27.5
ELEVATION=170
# Capture only while the sun is below this altitude (degrees). Lower = darker.
# NOTE: at high latitude this is never reached near midsummer (polar day).
SUN_LIMIT=-8.0
# Filename prefix, e.g. camera id + direction.
CAM_LABEL=cam_north

# --- Stacking ----------------------------------------------------------------
# Seconds per peak-hold stack (one output image per interval).
STACK_LENGTH=60

# --- Supervisor / robustness -------------------------------------------------
# How often (s) to re-check the sun gate while idle during daytime.
POLL_INTERVAL=60
# Kill + restart capture if no new image for this many stack-lengths (hang detect).
STALL_STACKS=3

# --- Retention ---------------------------------------------------------------
# Delete captures older than N days. 0 = keep forever.
RETENTION_DAYS=14
