# Copy to `.env` on fresnel and fill in. `.env` is gitignored — never commit secrets.
# These variables are substituted into config/config.yaml.template and read by the
# capturer/assembler. Values below are placeholders / proposed defaults.

# --- Camera / RTSP -----------------------------------------------------------
# Tapo requires a dedicated "camera account" created in the Tapo app for RTSP.
# The main TP-Link cloud login does NOT work here. (RTSP already works for you.)
TAPO_USERNAME=changeme
TAPO_PASSWORD=changeme
CAMERA_IP=192.168.1.50
CAMERA_PORT=554
# Single consumer, full res: stream1 = main. (birdnet-go separately uses stream2.)
CAMERA_STREAM=stream1

# --- Site / sun gate (day vs night mode switch) ------------------------------
LATITUDE=68.5
LONGITUDE=27.5
ELEVATION=170
# Below this sun altitude (deg) → night peak-hold mode; above → day frame mode.
# NOTE: at high latitude this is never reached near midsummer (polar day) →
# night mode simply never triggers; the day timelapse keeps running.
SUN_LIMIT=-8.0
# Filename prefix, e.g. camera id + direction.
CAM_LABEL=cam_north

# --- Capture -----------------------------------------------------------------
# Seconds between saved images, day and night (uniform timelapse cadence).
# Day: one plain frame per interval. Night: one peak-hold stack per interval.
INTERVAL=15

# --- Timelapse assembly ------------------------------------------------------
# Playback framerate of the assembled day/night timelapse videos.
TIMELAPSE_FPS=25

# --- Robustness --------------------------------------------------------------
# Kill + restart the capturer if no new image for this many intervals (hang).
STALL_INTERVALS=3

# --- Retention ---------------------------------------------------------------
# Prune individual JPG frames older than N days. 0 = keep forever.
FRAME_RETENTION_DAYS=14
# Prune assembled timelapse videos older than N days. 0 = keep forever.
VIDEO_RETENTION_DAYS=0
